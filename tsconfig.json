{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",           /* Было CommonJS */
    "moduleResolution": "Node16", /* Было node */
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}